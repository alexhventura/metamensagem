# Senha LOCAL do cofre (criptografia das chaves de API — NÃO é a chave sk- nem AIza)
SECRETS_PASSPHRASE="sua-frase-secreta-local"

# Provedor de curadoria: openai (ChatGPT, padrão) | gemini
FRASES_AI_PROVIDER=openai

# OpenAI — opcional em texto (menos seguro). Prefira npm run secrets:set-openai
# OPENAI_API_KEY="sk-..."
# OPENAI_MODEL=gpt-4o-mini

# Gemini — só se FRASES_AI_PROVIDER=gemini
# GEMINI_API_KEY="AIza..."
# GEMINI_MODEL=gemini-2.0-flash

# API Ninjas (opcional, import de citações)
# API_NINJAS_KEY=""

# Em produção, UI de chaves desligada por padrão
# ENABLE_DEV_SECRETS=true

APP_URL="http://localhost:3001"

# citei-api — URL da API (se estiver no ar) ou use dump em data/citei-api/dumps/quotes.json
# CITEI_API_URL=https://citei.herokuapp.com/api
