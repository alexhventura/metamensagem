# Senha LOCAL do cofre (criptografia das chaves de API — NÃO é a chave sk- nem AIza)
SECRETS_PASSPHRASE="sua-frase-secreta-local"

# Provedor de curadoria: openai (ChatGPT, padrão) | gemini
FRASES_AI_PROVIDER=openai

# OpenAI — opcional em texto (menos seguro). Prefira npm run secrets:set-openai
# OPENAI_API_KEY="sk-..."
# OPENAI_MODEL=gpt-4o-mini

# Gemini — só se FRASES_AI_PROVIDER=gemini
# GEMINI_API_KEY="AIza..."
# GEMINI_MODEL=gemini-2.0-flash

# API Ninjas (opcional, import de citações)
# API_NINJAS_KEY=""

# Em produção, UI de chaves desligada por padrão
# ENABLE_DEV_SECRETS=true

APP_URL="http://localhost:3001"

# Analytics (build Vite — definir na Vercel Production)
# VITE_GA4_MEASUREMENT_ID="G-XXXXXXXXXX"
# VITE_CLARITY_PROJECT_ID="xxxxxxxxxx"

# IndexNow (indexação rápida após sitemap)
# INDEXNOW_KEY="sua-chave-secreta-32chars"

# Tradução / fila (Vercel)
# MYMEMORY_EMAIL="seu@email.com"
# BLOB_READ_WRITE_TOKEN="vercel_blob_..."

# citei-api — URL da API (se estiver no ar) ou use dump em data/citei-api/dumps/quotes.json
# CITEI_API_URL=https://citei.herokuapp.com/api

# --- Supabase (frontend — chaves públicas) ---
# Local: VITE_* abaixo. Vercel+GitHub (integração): SUPABASE_* ou NEXT_PUBLIC_SUPABASE_* (automático)
# Dashboard: Project Settings → API
VITE_SUPABASE_URL="https://SEU_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="sua-chave-publica-anon-ou-publishable"

# Apenas scripts server-side / CI — NUNCA prefixo VITE_ (não vai para o bundle)
# SUPABASE_SERVICE_ROLE_KEY="sua-service-role-key"
# Conexão direta (IPv6): Dashboard → Database → Connection string → Direct
# DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.zkugnthamuwsrvikymii.supabase.co:5432/postgres"
# Import local (script em scripts/importarShards.js — pasta /scripts/ não vai ao Git):
#   npm run frases:import:supabase:dry
