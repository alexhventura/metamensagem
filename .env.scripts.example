# Copie para .env.scripts.local — usado por setup-supabase / import (NÃO coloque no .env.local)
# A senha do Postgres fica AQUI, não no .env.local (só VITE_* no .env.local).
SUPABASE_PROJECT_REF=hnrulfjomufpxkitvfqg
POSTGRES_PASSWORD=sua-database-password-do-painel-database
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key
SECRETS_PASSPHRASE=sua-frase-secreta-local

# Session pooler (Connect no painel) — tem prioridade sobre POSTGRES_PASSWORD sozinho
# Substitua SUA_SENHA_NOVA pela senha do Database (ou rode: npm run supabase:sync-db-url)
