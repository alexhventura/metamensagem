# Ignora a pasta inteira de scripts para proteger ferramentas administrativas
/scripts/*

# Abre uma exceção EXCLUSIVA para o validador que a Vercel precisa rodar
!/scripts/check-vercel-supabase-env.mjs

# Artefatos sensíveis gerados por scripts
scripts/.import-credentials.json
scripts/*-credentials.json

# Monolitos gerados localmente (GitHub >100MB); site usa frases-v2/shards + feed-sample
public/frases-cms.json
public/frases-index.json
public/frases-v2/id-index.json
content/frases/frases.json

.vercel
