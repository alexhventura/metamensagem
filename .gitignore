node_modules/
build/
dist/
.next/
coverage/
.DS_Store
*.log

# --- InfoSec: variáveis de ambiente (nunca commitar credenciais) ---
.env
.env.local
.env.production
.env.development
.env.test
.env.*
*.env
!.env.example

# Ignora a pasta inteira de scripts locais
/scripts/*

# Abre exceções exclusivas para os scripts que a Vercel precisa ler no build
!/scripts/check-vercel-supabase-env.mjs
!/scripts/build-frase-id-index.mjs
!/scripts/inject-prerender-shell.mjs

# Artefatos sensíveis gerados por scripts
scripts/.import-credentials.json
scripts/*-credentials.json

# Monolitos gerados localmente (GitHub >100MB); site usa frases-v2/shards + feed-sample
public/frases-cms.json
public/frases-index.json
public/frases-v2/id-index.json
content/frases/frases.json

.vercel
