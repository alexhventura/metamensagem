{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "processar-dados": "node processar_dados.js",
    "generate-brand": "node scripts/sync-favicon-kit.mjs",
    "enrich-content": "node scripts/enrich-external-content.mjs",
    "enrich-content:force": "node scripts/enrich-external-content.mjs --force",
    "build": "node build-scripts/check-vercel-supabase-env.mjs && node build-scripts/build-frase-id-index.mjs && vite build && node build-scripts/inject-prerender-shell.mjs",
    "test:lighthouse-guards": "node scripts/test-lighthouse-guards.mjs",
    "build:local": "node scripts/enrich-external-content.mjs && node prepare-data.cjs && node build-scripts/build-frase-id-index.mjs && node scripts/generate-sitemap.mjs && vite build",
    "frases:id-index": "node build-scripts/build-frase-id-index.mjs",
    "supabase:config": "node setup-supabase/configurar.mjs",
    "supabase:migrate": "node setup-supabase/apply-migration.mjs",
    "frases:import:supabase": "node scripts/importarShards.js",
    "frases:import:supabase:dry": "node scripts/importarShards.js --dry-run",
    "seo:indexnow": "node scripts/submit-indexnow.mjs",
    "frases:seo:all": "npm run frases:seo:phase6 && npm run frases:sitemap:intl",
    "content:sync": "node scripts/migrate-frases-to-content.mjs && node scripts/build-content-metadata.mjs",
    "frases:split": "node scripts/split-frases-by-autor.mjs",
    "frases:migrate": "node scripts/migrate-all-frases.mjs",
    "frases:migrate:dry": "node scripts/migrate-all-frases.mjs --dry-run",
    "frases:prepare": "node scripts/split-frases-by-autor.mjs && node prepare-data.cjs",
    "frases:rebuild": "node scripts/migrate-all-frases.mjs && node scripts/build-content-metadata.mjs && node prepare-data.cjs",
    "frases:explicacao": "tsx scripts/generate-frases-explicacao.mjs",
    "frases:explicacao:apply": "tsx scripts/generate-frases-explicacao.mjs --apply-cache",
    "secrets:set-gemini": "tsx scripts/set-gemini-key.ts",
    "secrets:set-openai": "tsx scripts/set-openai-key.ts",
    "frases:curate:api": "node scripts/curate-api-frases.mjs",
    "frases:curate:api:promote": "node scripts/curate-api-frases.mjs --promote",
    "frases:import": "tsx scripts/import-frases-pipeline.ts",
    "frases:import:dry": "tsx scripts/import-frases-pipeline.ts --dry-run",
    "frases:import:csv": "tsx scripts/import-frases-csv.ts",
    "frases:import:csv:all": "tsx scripts/import-csv-all-batches.ts",
    "frases:import:citei": "tsx scripts/import-citei-dataset.ts",
    "frases:import:citei:all": "tsx scripts/import-citei-all-batches.ts",
    "frases:normalize": "tsx scripts/normalize-acervo.mjs",
    "frases:curate:all": "tsx scripts/curate-frases-all-batches.mjs",
    "frases:finalize": "node scripts/finalize-metamensagem-pipeline.mjs",
    "frases:enrich:phase2": "tsx scripts/enrich-acervo-phase2.ts",
    "frases:seo:phase3": "tsx scripts/build-seo-graph-phase3.ts",
    "frases:seo:phase6": "tsx scripts/build-global-seo-phase6.ts",
    "frases:sitemap:intl": "node scripts/generate-sitemap-intl.mjs",
    "seo:all": "npm run frases:sitemap:intl && npm run seo:indexnow",
    "translations:merge": "node scripts/merge-translation-queue.mjs",
    "translations:sync-demand": "node scripts/sync-translation-demand.mjs",
    "translations:pull-demand": "node scripts/pull-translation-demand.mjs",
    "translation-report": "node scripts/translation-report.mjs",
    "build-translations": "node scripts/build-translations.mjs",
    "test:image-layout": "tsx scripts/test-image-text-layout.mjs",
    "test:header-home-nav": "tsx scripts/test-header-home-nav.mjs",
    "test:export-download": "tsx scripts/test-export-download.mjs",
    "test:cta-wiring": "tsx scripts/test-cta-wiring.mjs",
    "test:e2e-critical": "playwright test e2e/critical.spec.ts",
    "test:critical": "npm run test:header-home-nav && npm run test:export-download && npm run test:cta-wiring && npm run test:image-layout && npm run test:lighthouse-guards",
    "translations:weekly": "npm run translations:pull-demand && npm run translation-report && npm run build-translations && node scripts/merge-translation-queue.mjs data/translation-batch-built.json",
    "content:build": "npm run content:sync && node prepare-data.cjs",
    "next:dev": "next dev -p 3001",
    "next:build": "next build",
    "next:start": "next start -p 3001",
    "preview": "vite preview",
    "analyze": "cross-env ANALYZE=true vite build",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@supabase/supabase-js": "^2.107.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vercel/blob": "^0.27.3",
    "@vercel/og": "^0.6.8",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "file-saver": "^2.0.5",
    "fuse.js": "^7.1.0",
    "html-to-image": "^1.11.13",
    "html2canvas": "^1.4.1",
    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.546.0",
    "modern-screenshot": "^4.7.0",
    "motion": "^12.23.24",
    "next": "^15.5.18",
    "pg": "^8.21.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.3.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/express": "^4.17.21",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^22.14.0",
    "@types/react": "19.2.15",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "esbuild": "^0.25.0",
    "rollup-plugin-visualizer": "^5.14.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.14",
    "to-ico": "^1.1.5",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
