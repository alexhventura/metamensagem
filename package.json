{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "processar-dados": "node processar_dados.js",
    "generate-brand": "node scripts/sync-favicon-kit.mjs",
    "enrich-content": "node scripts/enrich-external-content.mjs",
    "enrich-content:force": "node scripts/enrich-external-content.mjs --force",
    "build": "node scripts/enrich-external-content.mjs && node prepare-data.cjs && node scripts/generate-sitemap.mjs && vite build",
    "content:sync": "node scripts/migrate-frases-to-content.mjs && node scripts/build-content-metadata.mjs",
    "content:build": "npm run content:sync && node prepare-data.cjs",
    "next:dev": "next dev -p 3001",
    "next:build": "next build",
    "next:start": "next start -p 3001",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "fuse.js": "^7.1.0",
    "html2canvas": "^1.4.1",
    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.546.0",
    "modern-screenshot": "^4.7.0",
    "motion": "^12.23.24",
    "next": "^15.5.18",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.3.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "19.2.15",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.14",
    "to-ico": "^1.1.5",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
